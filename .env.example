# 複製此檔為 .env 並填入你的真實金鑰。.env 已被 .gitignore 忽略，不會提交。
#
# 派網 API 金鑰：到派網網頁 -> 帳號 -> API 管理 建立。
# 建議：初期只勾選「讀取」與「現貨交易」權限，切勿開啟「提現」權限。
PIONEX_API_KEY=your_api_key_here
PIONEX_API_SECRET=your_api_secret_here

# (選用) Telegram 通知：到 @BotFather 建立 bot 取得 token，chat_id 可向 @userinfobot 查。
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# (選用) Webhook 共享密鑰：訊號來源 POST 時需帶上，避免被陌生人觸發下單。
WEBHOOK_SECRET=
